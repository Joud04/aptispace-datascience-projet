# Cache Python
__pycache__/
*.py[cod]
*$py.class

# Notebooks Jupyter
.ipynb_checkpoints/
# Dossier de build contenant tous les fichiers générés (scripts, qmd compilés, logs)
build/


# Environnements Virtuels
venv/
.venv/
env/
.env/

# Données : les données brutes sont versionnées pour que l'équipe puisse tester.
# Seules les données dérivées (générées par les notebooks) restent ignorées.
data/processed/*
!data/processed/.gitkeep

# Quarto & Rendu
.quarto/
*_files/
*_cache/

# Fichiers OS
.DS_Store
Thumbs.db

*.pdf
*.html
# Exception : les tableaux de bord sont des livrables du projet (pas des artefacts de build)
!dashboard.html
!dashboard_operational.html
/.quarto/
**/*.quarto_ipynb
